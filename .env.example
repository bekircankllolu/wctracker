# Supabase bağlantısı — bu dosyayı .env.local olarak kopyalayıp değerleri doldurun.
# Değerleri Supabase panelinde Project Settings > API bölümünde bulabilirsiniz.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Eski projeler için VITE_SUPABASE_ANON_KEY değişkeni de desteklenir.
